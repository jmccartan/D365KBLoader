# D365 Knowledge Base Loader — environment overrides
#
# This file is OPTIONAL. The GUI saves your settings to ~/.d365kbloader/settings.json
# automatically; you only need .env if you want to:
#   - Override settings for scripted CLI runs
#   - Use a custom Entra app registration instead of the default
#   - Force az CLI auth (the default is hybrid: MSAL + az CLI)
#
# Copy this file to `.env` to use it. Don't commit `.env` (it's in .gitignore).

# ── Required for any run ─────────────────────────────────────────────
# Your D365 environment URL
DATAVERSE_URL=https://your-org.crm.dynamics.com

# ── Input source (use ONE of these) ──────────────────────────────────
# SharePoint folder URL — accepts address-bar URLs OR sharing links
SHAREPOINT_FOLDER_URL=https://your-tenant.sharepoint.com/sites/YourSite/Shared Documents/YourFolder
# Or a local folder
# LOCAL_FOLDER=C:\Users\you\OneDrive - Company\Documents\KB Articles

# Where HTML files and run logs are written
OUTPUT_DIR=./output

# When an article with the same title already exists: skip | update | duplicate
EXISTING_ARTICLE_MODE=skip

# ── Authentication (advanced — defaults work without any of this) ────
#
# By default the app uses HYBRID authentication:
#   - Microsoft Graph (SharePoint) → MSAL with the Microsoft Graph PowerShell
#     public client ID, which has Files.Read.All / Sites.Read.All
#     pre-authorized. No app registration required.
#   - Dataverse → Azure CLI (az login)
#
# To use your own Entra app registration instead of the default public
# client (e.g. for branded sign-in or stricter consent control), register
# a public client app in https://entra.microsoft.com with these
# delegated permissions:
#   - Microsoft Graph: Sites.Read.All, Files.Read.All
# Then set:
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Tenant ID - auto-detected from the az CLI session if not set.
# Only needed for MSAL when targeting a specific tenant.
# AZURE_TENANT_ID=

# Force az CLI auth for everything (skips the MSAL flow). Use this if your
# tenant policy blocks the default MSAL public client.
# Values: az_cli  (anything else means hybrid default)
# KB_LOADER_AUTH=
