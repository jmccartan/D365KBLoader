# Dataverse / D365 Environment
DATAVERSE_URL=https://your-org.crm.dynamics.com

# ── Authentication ─────────────────────────────────────────────────
# AUTH_METHOD: "auto" (default), "msal", or "az_cli"
#   auto   = use MSAL if AZURE_CLIENT_ID is set, otherwise fall back to az CLI
#   msal   = MSAL interactive browser login (requires AZURE_CLIENT_ID + AZURE_TENANT_ID)
#   az_cli = Azure CLI (requires az login + Azure subscription)
AUTH_METHOD=auto

# For MSAL auth: register a public client app in Entra ID (free, no subscription needed)
#   1. Go to https://entra.microsoft.com → App registrations → New registration
#   2. Name: "D365KBLoader", Supported account types: "Single tenant"
#   3. Redirect URI: "http://localhost" (type: Mobile and desktop applications)
#   4. Under API permissions, add: Microsoft Graph → Sites.Read.All, Files.Read.All
#      and Dynamics CRM → user_impersonation
#   5. Copy the Application (client) ID and Directory (tenant) ID below
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# Input source (use ONE of these, or pass via CLI args)
# Option 1: SharePoint folder URL (requires Graph access)
SHAREPOINT_FOLDER_URL=https://your-tenant.sharepoint.com/sites/YourSite/Shared Documents/YourFolder
# Option 2: Local folder path (e.g. OneDrive-synced SharePoint folder)
# LOCAL_FOLDER=C:\Users\you\OneDrive - Company\Documents\KB Articles

# Local output directory for HTML files (default: ./output)
OUTPUT_DIR=./output

# Idempotency: "skip" existing articles, "update" them, or "duplicate" (create new)
EXISTING_ARTICLE_MODE=skip
